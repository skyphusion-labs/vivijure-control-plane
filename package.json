{
  "name": "vivijure-control-plane",
  "version": "1.3.0",
  "private": true,
  "description": "Hosted control plane for Vivijure Studio: tenancy, onboarding, provisioning",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit",
